# ZAO Video Editor - environment variables
# Copy to .env (gitignored) and fill in the keys you need. All are OPTIONAL -
# the app runs fully local without any of them; these only unlock extra engines.

# Groq - fast cloud Whisper transcription. https://console.groq.com (free tier).
# Used by the "groq" transcription engine (backend/services/groq_service.py).
GROQ_API_KEY=

# Hugging Face token - required for speaker diarization (pyannote models are
# gated). https://huggingface.co/settings/tokens
# Used by backend/services/diarization.py.
HF_TOKEN=

# OpenAI - optional LLM backend for content generation (recap, clips, show
# notes, social posts) and transcript polish. Ollama (local) is preferred and
# tried first; OpenAI is the cloud fallback.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Publishing (optional - enables the Post/Upload buttons in the Studio) ---
# Farcaster, via Neynar (the ZAO app already uses Neynar):
NEYNAR_API_KEY=
FARCASTER_SIGNER_UUID=
# X / Twitter (developer account -> app -> keys + access token/secret):
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
# YouTube: put a Google OAuth client at backend/credentials.json, then run
#   python scripts/youtube_auth.py   (one-time browser auth)
