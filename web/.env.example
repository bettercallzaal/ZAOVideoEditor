# ZAO Recordings review UI - environment

# Supabase project (Postgres + Auth). Create a project at supabase.com, run the
# migration in web/supabase/migrations/0001_init.sql, then paste these.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The Python media worker (FastAPI engine on the VPS) - transcribe / render /
# serve-video. Defaults to localhost:8000 for local dev.
NEXT_PUBLIC_WORKER_URL=http://localhost:8000
